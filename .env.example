# Server
PORT=8787
HOST=0.0.0.0

# Production: directory of Vite build (index.html). Relative to process cwd.
# Docker image sets this to "public". Local prod after `pnpm build:web` can omit
# (server auto-detects apps/web/dist).
# WEB_DIST=apps/web/dist


# DanDanPlay credentials (optional)
# Leave empty to use the same built-in client keys as agefans-enhance (local/dev).
# For production, apply open-platform keys at https://www.dandanplay.com/
DANDAN_APP_ID=
DANDAN_APP_SECRET=

# Optional UA for Bangumi / product APIs / plugin HTML fetches
BANGUMI_USER_AGENT=aniku/0.1
# DanDanPlay and other product-identity APIs (not site scraping)
PRODUCT_USER_AGENT=aniku/0.1
# Browser-like UA for third-party HTML/media fetches
DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

# Optional KazumiRules shop URLs (defaults match Kazumi ApiEndpoints)
# PLUGIN_SHOP=https://raw.githubusercontent.com/Predidit/KazumiRules/main/
# PLUGIN_SHOP_MIRROR=https://raw.gitcode.com/gh_mirrors/ka/KazumiRules/raw/main/
