{
  "name": "aniku",
  "private": true,
  "version": "0.1.0",
  "description": "Aniku — browser anime client: Bangumi metadata, plugin sources, danmaku, collections",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "pnpm --filter @aniku/web dev",
    "dev:server": "pnpm --filter @aniku/server dev",
    "dev:parallel": "pnpm -r --parallel --filter @aniku/web --filter @aniku/server dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @aniku/web build",
    "build:server": "pnpm --filter @aniku/server build",
    "start": "pnpm --filter @aniku/server start",
    "start:prod": "pnpm build && pnpm start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
